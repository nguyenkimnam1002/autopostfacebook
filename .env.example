# Shopee Affiliate khong co Open API trong flow nay.
# Dung bien nay neu ban co URL Facebook Page de tool mo trang sau khi tao draft.
FACEBOOK_PAGE_URL=https://www.facebook.com/your-page
META_GRAPH_VERSION=v25.0
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_LOGIN_CONFIG_ID=
# Optional. Neu de trong, tool tu dung http://127.0.0.1:8001/affiliate_hot_tool/facebook/callback
FACEBOOK_REDIRECT_URI=

# Tuy chon: neu sau nay dung API hop le de lay trend/search.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# SERPAPI_KEY=

# Optional: needed if Shopee public search returns 403.
SHOPEE_COOKIE=
