# Copy file nay thanh .env roi dien gia tri that.
# Khong commit .env vi co token, cookie, app secret.

# URL Fanpage dung de tool mo trang Facebook khi can fallback/manual.
# Cach lay: mo Fanpage tren trinh duyet va copy URL.
# Vi du: https://www.facebook.com/ten-page-cua-ban
FACEBOOK_PAGE_URL=

# Phien ban Meta Graph API.
# Cach lay/chon: xem version dang dung trong Meta App Dashboard hoac Graph API Explorer.
# Neu khong chac, dung version hien tai cua tool: v25.0
META_GRAPH_VERSION=

# ID Fanpage muon dang bai.
# Cach lay:
# 1. Vao Page Facebook -> About/Gioi thieu -> Page transparency/Thong tin Page neu co hien ID.
# 2. Hoac dung Graph API Explorer goi /me/accounts voi User Token co quyen pages_show_list.
# 3. Lay truong id cua Page dung can dang.
FACEBOOK_PAGE_ID=

# Page Access Token dung de dang bai truc tiep.
# Cach lay khuyen nghi:
# 1. Dien FACEBOOK_APP_ID va FACEBOOK_APP_SECRET ben duoi.
# 2. Mo tool web -> dan User Token vao o "Token lau dai" -> bam "Dung token lau dai".
# 3. Tool se tu doi va luu Page token vao data/facebook_auth.json, nen bien nay co the de trong.
# Cach thu cong: Graph API Explorer -> /me/accounts -> copy access_token cua Page.
FACEBOOK_PAGE_ACCESS_TOKEN=


# App ID trong Meta for Developers.
# Cach lay: https://developers.facebook.com/apps -> chon app -> Settings -> Basic -> App ID.
FACEBOOK_APP_ID=

# App Secret trong Meta for Developers.
# Cach lay: https://developers.facebook.com/apps -> chon app -> Settings -> Basic -> App secret -> Show.
FACEBOOK_APP_SECRET=

# Tuy chon: Groq API key de cham diem/phan tich san pham bang AI.
# Cach lay: tao key trong Groq Console, sau do dan vao day.
# Neu de trong, tool van chay bang scoring local.
GROQ_API_KEY=

# Model Groq muon dung.
# Cach lay/chon: xem danh sach model trong Groq Console/docs.
# Vi du thuong dung: llama-3.3-70b-versatile
GROQ_MODEL=

# Tuy chon: neu sau nay dung API hop le de lay trend/search.
# Cach lay: tao API key trong SerpApi dashboard.
# SERPAPI_KEY=


# OAuth callback cua Facebook Login.
# Cach dat:
# - Chay local mac dinh: http://127.0.0.1:8001/affiliate_hot_tool/facebook/callback
# - Neu Meta yeu cau public HTTPS callback, dung ngrok/cloudflared roi dien URL public.
# Luu y: URL nay phai trung voi Valid OAuth Redirect URIs trong Meta App Dashboard.
FACEBOOK_REDIRECT_URI=
